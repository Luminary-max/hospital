{"remainingRequest":"F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\node_modules\\babel-loader\\lib\\index.js!F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\node_modules\\cache-loader\\dist\\cjs.js??ref--1-0!F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\src\\views\\DoctorQueue.vue?vue&type=script&lang=js&","dependencies":[{"path":"F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\src\\views\\DoctorQueue.vue","mtime":1781189294990},{"path":"F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\babel.config.js","mtime":1673698822000},{"path":"F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\node_modules\\babel-loader\\lib\\index.js","mtime":456789000000},{"path":"F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"F:\\学习通作业\\软件工程实践2\\医院门诊管理系统\\HospitalVue 2\\HospitalVue\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["request","jwtDecode","getToken","name","data","dId","currentPatient","waitingList","methods","refreshQueue","loadQueue","res","get","params","status","find","p","q_state","filter","e","console","error","callNext","$message","success","startConsult","$router","push","o_id","p_id","skipNumber","qId","q_id","warning","reQueue","row","created","token","decoded","sub"],"sources":["src/views/DoctorQueue.vue"],"sourcesContent":["<template>\n  <el-card>\n    <div slot=\"header\">\n      <span><i class=\"el-icon-s-promotion\"></i> 医生叫号面板</span>\n      <el-button type=\"success\" size=\"small\" style=\"float:right; margin-left:10px;\" @click=\"callNext\"\n        :disabled=\"waitingList.length === 0\">\n        <i class=\"el-icon-phone\"></i> 呼叫下一号\n      </el-button>\n      <el-button type=\"warning\" size=\"small\" style=\"float:right;\" @click=\"refreshQueue\">\n        <i class=\"el-icon-refresh\"></i> 刷新\n      </el-button>\n    </div>\n    <!-- 当前呼叫患者 -->\n    <el-card shadow=\"always\" v-if=\"currentPatient\" style=\"margin-bottom:20px; background:#f0f9eb;\">\n      <div style=\"display:flex; align-items:center; justify-content:space-between;\">\n        <div>\n          <span style=\"font-size:24px; font-weight:bold; color:#67C23A;\">{{ currentPatient.q_number }}</span>\n          <span style=\"font-size:18px; margin-left:20px;\">{{ currentPatient.p_name }}</span>\n          <el-tag type=\"success\" style=\"margin-left:10px;\">正在就诊</el-tag>\n        </div>\n        <div>\n          <el-button type=\"primary\" size=\"small\" @click=\"startConsult\">开始接诊</el-button>\n          <el-button type=\"danger\" size=\"small\" @click=\"skipNumber\">过号处理</el-button>\n        </div>\n      </div>\n    </el-card>\n    <el-alert v-else title=\"暂无呼叫患者，请点击「呼叫下一号」\" type=\"info\" show-icon style=\"margin-bottom:20px;\"></el-alert>\n    <!-- 候诊列表 -->\n    <h4>候诊列表（{{ waitingList.length }} 人等待）</h4>\n    <el-table :data=\"waitingList\" border stripe style=\"width:100%\">\n      <el-table-column type=\"index\" label=\"序号\" width=\"60\"></el-table-column>\n      <el-table-column prop=\"q_number\" label=\"排队号码\" width=\"120\"></el-table-column>\n      <el-table-column prop=\"p_name\" label=\"患者姓名\" width=\"120\"></el-table-column>\n      <el-table-column prop=\"q_create_time\" label=\"取号时间\" width=\"180\"></el-table-column>\n      <el-table-column label=\"状态\" width=\"120\">\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.q_state === 0\" type=\"warning\">等待中</el-tag>\n          <el-tag v-else-if=\"scope.row.q_state === 2\" type=\"danger\">已过号</el-tag>\n          <el-tag v-else type=\"success\">已就诊</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"200\">\n        <template slot-scope=\"scope\">\n          <el-button v-if=\"scope.row.q_state === 2\" type=\"primary\" size=\"mini\" @click=\"reQueue(scope.row)\">重新排入</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n  </el-card>\n</template>\n<script>\nimport request from \"@/utils/request.js\";\nimport jwtDecode from \"jwt-decode\";\nimport { getToken } from \"@/utils/storage.js\";\nexport default {\n  name: \"DoctorQueue\",\n  data() {\n    return {\n      dId: \"\",\n      currentPatient: null,\n      waitingList: []\n    };\n  },\n  methods: {\n    refreshQueue() {\n      this.loadQueue();\n    },\n    async loadQueue() {\n      try {\n        const res = await request.get(\"queue/listByDoctor\", { params: { dId: this.dId } });\n        if (res.data.status === 200) {\n          const data = res.data.data || [];\n          this.currentPatient = data.find(p => p.q_state === 1) || null;\n          this.waitingList = data.filter(p => p.q_state === 0 || p.q_state === 2);\n        }\n      } catch(e) { console.error(e); }\n    },\n    async callNext() {\n      try {\n        const res = await request.get(\"queue/callNext\", { params: { dId: this.dId } });\n        if (res.data.status === 200) {\n          this.$message.success(\"呼叫成功！\");\n          this.loadQueue();\n        }\n      } catch(e) { console.error(e); }\n    },\n    startConsult() {\n      if (this.currentPatient) {\n        this.$router.push(\"/dealOrder?oId=\" + this.currentPatient.o_id + \"&pId=\" + this.currentPatient.p_id);\n      }\n    },\n    async skipNumber() {\n      if (!this.currentPatient) return;\n      try {\n        const res = await request.get(\"queue/skipNumber\", { params: { qId: this.currentPatient.q_id } });\n        if (res.data.status === 200) {\n          this.$message.warning(\"已标记为过号\");\n          this.loadQueue();\n        }\n      } catch(e) { console.error(e); }\n    },\n    async reQueue(row) {\n      try {\n        const res = await request.get(\"queue/callNext\", { params: { dId: this.dId, reQueue: row.q_id } });\n        if (res.data.status === 200) {\n          this.$message.success(\"已重新排入队列\");\n          this.loadQueue();\n        }\n      } catch(e) { console.error(e); }\n    }\n  },\n  created() {\n    const token = getToken();\n    if (token) {\n      const decoded = jwtDecode(token);\n      this.dId = decoded.dId || decoded.sub;\n    }\n    this.loadQueue();\n  }\n};\n</script>\n"],"mappings":"AAkDA,OAAAA,OAAA;AACA,OAAAC,SAAA;AACA,SAAAC,QAAA;AACA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,GAAA;MACAC,cAAA;MACAC,WAAA;IACA;EACA;EACAC,OAAA;IACAC,aAAA;MACA,KAAAC,SAAA;IACA;IACA,MAAAA,UAAA;MACA;QACA,MAAAC,GAAA,SAAAX,OAAA,CAAAY,GAAA;UAAAC,MAAA;YAAAR,GAAA,OAAAA;UAAA;QAAA;QACA,IAAAM,GAAA,CAAAP,IAAA,CAAAU,MAAA;UACA,MAAAV,IAAA,GAAAO,GAAA,CAAAP,IAAA,CAAAA,IAAA;UACA,KAAAE,cAAA,GAAAF,IAAA,CAAAW,IAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAC,OAAA;UACA,KAAAV,WAAA,GAAAH,IAAA,CAAAc,MAAA,CAAAF,CAAA,IAAAA,CAAA,CAAAC,OAAA,UAAAD,CAAA,CAAAC,OAAA;QACA;MACA,SAAAE,CAAA;QAAAC,OAAA,CAAAC,KAAA,CAAAF,CAAA;MAAA;IACA;IACA,MAAAG,SAAA;MACA;QACA,MAAAX,GAAA,SAAAX,OAAA,CAAAY,GAAA;UAAAC,MAAA;YAAAR,GAAA,OAAAA;UAAA;QAAA;QACA,IAAAM,GAAA,CAAAP,IAAA,CAAAU,MAAA;UACA,KAAAS,QAAA,CAAAC,OAAA;UACA,KAAAd,SAAA;QACA;MACA,SAAAS,CAAA;QAAAC,OAAA,CAAAC,KAAA,CAAAF,CAAA;MAAA;IACA;IACAM,aAAA;MACA,SAAAnB,cAAA;QACA,KAAAoB,OAAA,CAAAC,IAAA,0BAAArB,cAAA,CAAAsB,IAAA,kBAAAtB,cAAA,CAAAuB,IAAA;MACA;IACA;IACA,MAAAC,WAAA;MACA,UAAAxB,cAAA;MACA;QACA,MAAAK,GAAA,SAAAX,OAAA,CAAAY,GAAA;UAAAC,MAAA;YAAAkB,GAAA,OAAAzB,cAAA,CAAA0B;UAAA;QAAA;QACA,IAAArB,GAAA,CAAAP,IAAA,CAAAU,MAAA;UACA,KAAAS,QAAA,CAAAU,OAAA;UACA,KAAAvB,SAAA;QACA;MACA,SAAAS,CAAA;QAAAC,OAAA,CAAAC,KAAA,CAAAF,CAAA;MAAA;IACA;IACA,MAAAe,QAAAC,GAAA;MACA;QACA,MAAAxB,GAAA,SAAAX,OAAA,CAAAY,GAAA;UAAAC,MAAA;YAAAR,GAAA,OAAAA,GAAA;YAAA6B,OAAA,EAAAC,GAAA,CAAAH;UAAA;QAAA;QACA,IAAArB,GAAA,CAAAP,IAAA,CAAAU,MAAA;UACA,KAAAS,QAAA,CAAAC,OAAA;UACA,KAAAd,SAAA;QACA;MACA,SAAAS,CAAA;QAAAC,OAAA,CAAAC,KAAA,CAAAF,CAAA;MAAA;IACA;EACA;EACAiB,QAAA;IACA,MAAAC,KAAA,GAAAnC,QAAA;IACA,IAAAmC,KAAA;MACA,MAAAC,OAAA,GAAArC,SAAA,CAAAoC,KAAA;MACA,KAAAhC,GAAA,GAAAiC,OAAA,CAAAjC,GAAA,IAAAiC,OAAA,CAAAC,GAAA;IACA;IACA,KAAA7B,SAAA;EACA;AACA"}]}