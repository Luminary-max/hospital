mn prop=\"d_name\" label=\"医生\" width=\"120\"></el-table-column>\n      <el-table-column prop=\"o_start\" label=\"就诊日期\" width=\"180\"></el-table-column>\n      <el-table-column prop=\"o_drug\" label=\"药品\" width=\"200\"></el-table-column>\n      <el-table-column prop=\"o_total_price\" label=\"总价(元)\" width=\"120\"></el-table-column>\n      <el-table-column label=\"缴费状态\" width=\"120\">\n        <template slot-scope=\"scope\">\n          <el-tag v-if=\"scope.row.o_price_state === 0\" type=\"danger\">未缴费</el-tag>\n          <el-tag v-else type=\"success\">已缴费</el-tag>\n        </template>\n      </el-table-column>\n      <el-table-column label=\"操作\" width=\"150\">\n        <template slot-scope=\"scope\">\n          <el-button type=\"primary\" size=\"mini\" @click=\"viewDetail(scope.row)\">查看详情</el-button>\n        </template>\n      </el-table-column>\n    </el-table>\n    <div v-if=\"prescriptionList.length === 0\" style=\"text-align:center; padding:40px 0; color:#999;\">\n      暂无处方记录\n    </div>\n  </el-card>\n</template>\n<script>\nimport request from \"@/utils/request.js\";\nimport jwtDecode from \"jwt-decode\";\nimport { getToken } from \"@/utils/storage.js\";\nexport default {\n  name: \"MyPrescription\",\n  data() {\n    return { pId: null, prescriptionList: [] };\n  },\n  methods: {\n    async loadData() {\n      try {\n        const res = await request.get(\"patient/findOrderByPid\", { params: { pId: this.pId } });\n        if (res.data.status === 200) {\n          this.prescriptionList = (res.data.data || []).filter(o => o.o_drug || o.o_total_price > 0);\n        }\n      } catch(e) { console.error(e); }\n    },\n    viewDetail(row) {\n      this.$alert(\n        `<b>诊断：</b>${row.o_record || '无'}<br/>\n         <b>药品：</b>${row.o_drug || '无'}<br/>\n         <b>检查项目：</b>${row.o_check || '无'}<br/>\n         <b>医生建议：</b>${row.o_advice || '无'}`,\n        '处方详情',\n        { dangerouslyUseHTMLString: true }\n      );\n    }\n  },\n  created() {\n    const token = getToken();\n    if (token) {\n      const decoded = jwtDecode(token);\n      this.pId = decoded.pId || decoded.sub;\n    }\n    this.loadData();\n  }\n};\n</script>\n"],"mappings":"AA6BA,OAAAA,OAAA;AACA,OAAAC,SAAA;AACA,SAAAC,QAAA;AACA;EACAC,IAAA;EACAC,KAAA;IACA;MAAAC,GAAA;MAAAC,gBAAA;IAAA;EACA;EACAC,OAAA;IACA,MAAAC,SAAA;MACA;QACA,MAAAC,GAAA,SAAAT,OAAA,CAAAU,GAAA;UAAAC,MAAA;YAAAN,GAAA,OAAAA;UAAA;QAAA;QACA,IAAAI,GAAA,CAAAL,IAAA,CAAAQ,MAAA;UACA,KAAAN,gBAAA,IAAAG,GAAA,CAAAL,IAAA,CAAAA,IAAA,QAAAS,MAAA,CAAAC,CAAA,IAAAA,CAAA,CAAAC,MAAA,IAAAD,CAAA,CAAAE,aAAA;QACA;MACA,SAAAC,CAAA;QAAAC,OAAA,CAAAC,KAAA,CAAAF,CAAA;MAAA;IACA;IACAG,WAAAC,GAAA;MACA,KAAAC,MAAA,CACA,aAAAD,GAAA,CAAAE,QAAA;AACA,qBAAAF,GAAA,CAAAN,MAAA;AACA,uBAAAM,GAAA,CAAAG,OAAA;AACA,uBAAAH,GAAA,CAAAI,QAAA,WACA,QACA;QAAAC,wBAAA;MAAA,CACA;IACA;EACA;EACAC,QAAA;IACA,MAAAC,KAAA,GAAA1B,QAAA;IACA,IAAA0B,KAAA;MACA,MAAAC,OAAA,GAAA5B,SAAA,CAAA2B,KAAA;MACA,KAAAvB,GAAA,GAAAwB,OAAA,CAAAxB,GAAA,IAAAwB,OAAA,CAAAC,GAAA;IACA;IACA,KAAAtB,QAAA;EACA;AACA"}]}